    <PackageVersion Include="FastEndpoints.Security" Version="7.0.1" />
    <PackageVersion Include="MassTransit.RabbitMQ" Version="8.5.4" />
    <PackageVersion Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.9" />
